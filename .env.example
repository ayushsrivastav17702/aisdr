# ─── AI Providers (waterfall order: Groq → DeepSeek → OpenRouter → Anthropic) ───

# Provider 1 — Groq (free tier available at groq.com)
GROQ_API_KEY=

# Provider 2 — DeepSeek (cheap inference at platform.deepseek.com)
DEEPSEEK_API_KEY=

# Provider 3 — OpenRouter (unified gateway at openrouter.ai)
OPEN_ROUTER=
OPENROUTER_MODEL=openai/gpt-4o   # default model; change to any OpenRouter model slug

# Provider 4 — Anthropic (final fallback)
ANTHROPIC_API_KEY=

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=

# ─── Auth / Session ───────────────────────────────────────────────────────────
SESSION_SECRET=

# ─── Email delivery ───────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Other integrations ───────────────────────────────────────────────────────
PERPLEXITY_API_KEY=
REDIS_URL=
REDIS_DISABLED=true

# ─── App config ───────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=development
E2E_TESTING=false
